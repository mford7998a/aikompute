# Database
DB_PASSWORD=changeme_in_production

# AIClient-2-API internal API key (must match config.json REQUIRED_API_KEY)
AICLIENT2API_KEY=123456

# Antigravity-2-API internal API key (must match antigravity2api-nodejs .env AUTH_TOKEN)
ANTIGRAVITY2API_KEY=123456

# GitHub Copilot API (ericc-ch/copilot-api)
# No API key needed — authenticate once after first run:
#   docker exec -it copilot-api npx copilot-api start
# Then open the printed GitHub device-auth URL and approve.
# Token is persisted in ./copilot-api/data/ — survives restarts.
# COPILOT_API_BASE_URL is set automatically in docker-compose.yml.
# GitHub Models — free tier access to GPT-4o, Claude Sonnet, Gemini Pro
# Generate a PAT at https://github.com/settings/tokens (needs models:read scope)
GITHUB_TOKEN=github_pat_...

# Stripe billing (optional - leave empty to use prepaid credits only)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Gateway master key (for admin operations)
MASTER_API_KEY=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

# JWT secret for dashboard auth
JWT_SECRET=change-this-secret-in-production
