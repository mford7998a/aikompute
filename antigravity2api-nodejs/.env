# API key that clients must use to access this service
# Keep this in sync with ANTIGRAVITY2API_KEY in the root .env
API_KEY=123456

# Web admin panel credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=PLACEHOLDER_PASS

# JWT secret for admin panel sessions
JWT_SECRET=PLACEHOLDER_JWT_SECRET

# External base URL for generated image links (set to your domain in prod)
IMAGE_BASE_URL=http://localhost:8045

# Optional HTTP/SOCKS5 proxy for outbound requests
# PROXY=http://127.0.0.1:7890
