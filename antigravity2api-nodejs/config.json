{
  "server": {
    "port": 8045,
    "host": "0.0.0.0",
    "maxRequestSize": "500mb",
    "heartbeatInterval": 15000,
    "memoryThreshold": 100
  },
  "rotation": {
    "strategy": "round_robin",
    "requestCount": 50
  },
  "defaults": {
    "temperature": 1,
    "topP": 1,
    "topK": 50,
    "maxTokens": 32000,
    "thinkingBudget": 1024
  },
  "cache": {
    "modelListTTL": 3600000
  },
  "other": {
    "timeout": 300000,
    "skipProjectIdFetch": false,
    "useNativeAxios": false,
    "useContextSystemPrompt": true,
    "passSignatureToClient": false
  },
  "api": {
    "version": "1.20.6"
  }
}